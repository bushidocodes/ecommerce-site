{
  "name": "cookie-monsters",
  "version": "0.0.1",
  "description": "Buy and eat cookies please.",
  "type": "module",
  "main": "index.ts",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "vite build",
    "build-watch": "vite build --watch",
    "dev": "vite",
    "start[dev]": "tsx watch server/start.ts",
    "start[prod]": "tsx server/start.ts",
    "start": "pnpm run start[prod]",
    "seed": "tsx db/seed.ts",
    "postinstall": "pnpm run build",
    "format": "prettier --write app/ server/ db/ index.ts",
    "format:check": "prettier --check app/ server/ db/ index.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spmcbride1201/cookie-monsters.git"
  },
  "keywords": [
    "react",
    "redux"
  ],
  "author": "Sean McBride, Evan DiGiambattista, and Rachel Bird",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/spmcbride1201/cookie-monsters/issues"
  },
  "homepage": "https://github.com/spmcbride1201/cookie-monsters#readme",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@reduxjs/toolkit": "^2.8.2",
    "bcryptjs": "^3.0.3",
    "cookie-session": "^2.1.1",
    "debug": "^4.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "passport": "^0.7.0",
    "passport-github": "^1.1.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "redux": "^5.0.1",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-session": "^2.0.49",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github": "^1.1.13",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "morgan": "^1.11.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
