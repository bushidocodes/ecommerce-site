{
  "name": "cookie-monsters",
  "version": "0.0.1",
  "description": "Buy and eat cookies please.",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "test": "mocha --require ./babel-register.js --require ./test-setup.js app/**/*.test.jsx db/**/*.test.js server/**/*.test.js",
    "test-watch": "mocha --require ./babel-register.js --require ./test-setup.js --watch app/**/*.test.jsx db/**/*.test.js server/**/*.test.js",
    "build": "webpack",
    "build-watch": "webpack --watch",
    "start[dev]": "check-node-version --node >=18.0.0 && nodemon server/start.js",
    "start[prod]": "check-node-version --node >=18.0.0 && node server/start.js",
    "start": "check-node-version --node >=18.0.0 && pnpm run start[prod]",
    "seed": "node db/seed.js",
    "postinstall": "pnpm run build",
    "lint": "eslint app/ server/ db/ index.js",
    "lint:fix": "eslint --fix app/ server/ db/ index.js",
    "format": "prettier --write app/ server/ db/ index.js",
    "format:check": "prettier --check app/ server/ db/ index.js",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spmcbride1201/cookie-monsters.git"
  },
  "keywords": [
    "react",
    "redux"
  ],
  "author": "Sean McBride, Evan DiGiambattista, and Rachel Bird",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/spmcbride1201/cookie-monsters/issues"
  },
  "homepage": "https://github.com/spmcbride1201/cookie-monsters#readme",
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@reduxjs/toolkit": "^2.8.2",
    "axios": "^1.16.1",
    "bcrypt": "^5.1.1",
    "bluebird": "^3.4.7",
    "body-parser": "^1.15.2",
    "chalk": "^1.1.3",
    "check-node-version": "^4.2.1",
    "cookie-session": "^2.0.0-alpha.1",
    "express": "^4.14.0",
    "passport": "^0.3.2",
    "passport-facebook": "^2.1.1",
    "passport-github2": "^0.1.10",
    "passport-google-oauth": "^1.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.30.3",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@cfaester/enzyme-adapter-react-18": "^0.8.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/redux-logger": "^3.0.13",
    "ajv": "^8.20.0",
    "babel-loader": "^9.2.1",
    "chai": "^4.5.0",
    "cheerio": "1.0.0-rc.12",
    "debug": "^2.6.0",
    "enzyme": "^3.11.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-react": "^7.37.5",
    "mocha": "^10.8.2",
    "nodemon": "^3.1.14",
    "prettier": "^2.8.8",
    "sinon": "^19.0.5",
    "sinon-chai": "^3.7.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "volleyball": "^1.4.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^5.1.4"
  }
}
